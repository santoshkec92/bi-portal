# ============================================================================
# BI Portal configuration. Copy to .env for local dev. In containers, inject
# these via Kubernetes Secrets / Snowflake SECRET objects (see deploy/).
# ============================================================================

# --- App ---
ENVIRONMENT=development
BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# --- Session signing (CHANGE IN PRODUCTION) ---
SESSION_SECRET=dev-only-insecure-change-me

# --- Auth: "mock" (zero-dependency demo) or "okta" (real OAuth2 + PKCE) ---
AUTH_MODE=mock

# Required only when AUTH_MODE=okta:
OKTA_ISSUER=https://your-tenant.okta.com/oauth2/default
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_SCOPES=openid profile email groups
OKTA_GROUPS_CLAIM=groups

# --- Database (SQLite by default; swap to Postgres in prod) ---
DATABASE_URL=sqlite:///./bi_portal.db
# DATABASE_URL=postgresql+psycopg2://bi:bi@localhost:5432/bi_portal

# --- Claude / Anthropic (optional; falls back to deterministic mock) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest
CLAUDE_MAX_TOKENS=1024

# --- Snowflake (optional; falls back to synthetic dataset) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=ANALYTICS
SNOWFLAKE_ROLE=BI_PORTAL_READER
